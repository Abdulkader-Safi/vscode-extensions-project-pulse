{
  "name": "project-pulse",
  "displayName": "Project Pulse",
  "description": "Monitor health signals across all your client projects without leaving your editor.",
  "version": "0.0.1",
  "publisher": "AbdulkaderSafi",
  "author": {
    "name": "Safi",
    "email": "safi.abdulkader@gmail.com",
    "url": "https://abdulkadersafi.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulkader-Safi/vscode-extensions-project-pulse"
  },
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other"
  ],
  "icon": "img/Logo.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "project-pulse.openDashboard",
        "title": "Project Pulse: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Project Pulse",
      "properties": {
        "projectPulse.lighthouseApiKey": {
          "type": "string",
          "default": "",
          "description": "Google PageSpeed Insights API key for Lighthouse scans."
        },
        "projectPulse.checkInterval": {
          "type": "number",
          "default": 15,
          "description": "Default check interval in minutes."
        },
        "projectPulse.sslWarningDays": {
          "type": "number",
          "default": 30,
          "description": "SSL expiry warning threshold (days)."
        },
        "projectPulse.sslCriticalDays": {
          "type": "number",
          "default": 7,
          "description": "SSL expiry critical threshold (days)."
        },
        "projectPulse.uptimeWarningThreshold": {
          "type": "number",
          "default": 99.5,
          "description": "Uptime warning threshold (percentage)."
        },
        "projectPulse.lighthouseAlertThreshold": {
          "type": "number",
          "default": 80,
          "description": "Lighthouse score alert threshold."
        },
        "projectPulse.checks.ssl": {
          "type": "boolean",
          "default": true,
          "description": "Enable SSL certificate monitoring."
        },
        "projectPulse.checks.dns": {
          "type": "boolean",
          "default": true,
          "description": "Enable DNS resolution checks."
        },
        "projectPulse.checks.uptime": {
          "type": "boolean",
          "default": true,
          "description": "Enable uptime monitoring."
        },
        "projectPulse.checks.security": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency security audits."
        },
        "projectPulse.checks.lighthouse": {
          "type": "boolean",
          "default": false,
          "description": "Enable Lighthouse performance scans (requires API key)."
        },
        "projectPulse.checks.headers": {
          "type": "boolean",
          "default": true,
          "description": "Enable HTTP security headers check."
        },
        "projectPulse.dataDirectory": {
          "type": "string",
          "default": "~/.project-pulse",
          "description": "Directory for storing historical monitoring data."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.16",
    "esbuild": "^0.25.10",
    "esbuild-plugin-inline-import": "^1.1.0",
    "eslint": "^9.36.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
